{
  "name": "simple-test-app",
  "version": "1.0.0",
  "description": "A minimal web app demonstrating user authentication with React, Node.js, Express, MongoDB, JWT",
  "main": "server/index.js",
  "scripts": {
    "client": "npm start --prefix client",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.3",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^2.0.22",
    "eslint": "^8.45.0"
  },
